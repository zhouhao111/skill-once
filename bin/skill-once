#!/bin/bash
# SkillOnce CLI - 全局命令行工具

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ONCE="$HOME/.agents/skill-once"
CONFIG="$SKILL_ONCE/config.yaml"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 显示帮助
show_help() {
    echo -e "${BLUE}SkillOnce${NC} - 一次安装，处处可用"
    echo ""
    echo "用法: skill-once <命令> [选项]"
    echo ""
    echo "命令:"
    echo "  ${GREEN}init${NC}              初始化 SkillOnce"
    echo "  ${GREEN}add${NC} <名称> <路径>  添加新 skill"
    echo "  ${GREEN}add${NC} <URL>          从 GitHub 安装 skill"
    echo "  ${GREEN}remove${NC} <名称>     删除 skill"
    echo "  ${GREEN}sync${NC}              同步所有 skill 到各 Agent"
    echo "  ${GREEN}status${NC}            查看部署状态"
    echo "  ${GREEN}list${NC}              列出所有 skill"
    echo "  ${GREEN}detect${NC}            检测已安装的 Agent"
    echo "  ${GREEN}help${NC}              显示此帮助信息"
    echo ""
    echo "示例:"
    echo "  skill-once init                    # 首次安装时运行"
    echo "  skill-once add my-skill ./my-skill # 从本地添加 skill"
    echo "  skill-once add https://github.com/user/repo --skill xxx  # 从 GitHub 安装"
    echo "  skill-once sync                    # 同步到所有 Agent"
    echo "  skill-once status                  # 查看状态"
    echo ""
    echo "更多信息请访问: https://github.com/zhouhao111/skill-once"
}

# 初始化
cmd_init() {
    echo -e "${BLUE}🔧 SkillOnce 初始化${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/init.sh"
}

# 添加 skill
cmd_add() {
    # 从 GitHub 安装
    if [[ "$1" =~ ^https?:// ]] || [[ "$1" =~ ^git@ ]]; then
        local url="$1"
        shift
        
        # 解析 --skill 参数
        local skill_name=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                --skill)
                    skill_name="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        echo -e "${BLUE}📦 从 GitHub 安装 skill${NC}"
        echo ""
        bash "$SKILL_ONCE/scripts/add-from-git.sh" "$url" "$skill_name"
        return
    fi
    
    # 从本地路径安装
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo -e "${RED}❌ 用法: skill-once add <名称> <路径>${NC}"
        echo "   或: skill-once add <GitHub URL> --skill <名称>${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}📦 添加 skill: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/add.sh" "$1" "$2"
}

# 删除 skill
cmd_remove() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once remove <名称>${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}🗑️  删除 skill: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/remove.sh" "$1"
}

# 同步 skill
cmd_sync() {
    echo -e "${BLUE}🔄 同步 skill...${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/sync.sh" "$@"
}

# 查看状态
cmd_status() {
    echo -e "${BLUE}📊 部署状态${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/status.sh"
}

# 列出 skill
cmd_list() {
    # 读取配置
    if [ -f "$CONFIG" ]; then
        SKILL_DIR=$(grep "^skill_dir:" "$CONFIG" | awk '{print $2}')
        SKILL_DIR=$(eval echo "$SKILL_DIR")
    else
        SKILL_DIR="$HOME/.agents/.mySkillRepository"
    fi
    
    echo -e "${BLUE}📦 Skill 列表${NC}"
    echo ""
    echo "  仓库位置: $SKILL_DIR"
    echo ""
    
    if [ ! -d "$SKILL_DIR" ]; then
        echo -e "  ${RED}❌ 仓库目录不存在${NC}"
        exit 1
    fi
    
    count=0
    for skill in "$SKILL_DIR"/*/; do
        [ -d "$skill" ] || continue
        name=$(basename "$skill")
        echo "  - $name"
        ((count++))
    done
    
    echo ""
    echo "  共 $count 个 skill"
}

# 检测 Agent
cmd_detect() {
    echo -e "${BLUE}🔍 检测已安装的 Agent...${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/detect.sh"
}

# 主函数
main() {
    case "${1:-help}" in
        init)
            cmd_init
            ;;
        add)
            shift
            cmd_add "$@"
            ;;
        remove|rm)
            shift
            cmd_remove "$@"
            ;;
        sync)
            shift
            cmd_sync "$@"
            ;;
        status|st)
            cmd_status
            ;;
        list|ls)
            cmd_list
            ;;
        detect)
            cmd_detect
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}❌ 未知命令: $1${NC}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
