#!/bin/bash
# SkillOnce CLI - 像 git 一样优雅的 skill 管理

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ONCE="$HOME/.agents/skill-once"
CONFIG="$SKILL_ONCE/config.yaml"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 显示帮助
show_help() {
    echo -e "${BLUE}SkillOnce${NC} - 像 git 一样优雅的 skill 管理"
    echo ""
    echo "用法: skill-once <命令> [选项]"
    echo ""
    echo "${CYAN}基础命令:${NC}"
    echo "  ${GREEN}init${NC}              初始化 skill 仓库"
    echo "  ${GREEN}add${NC} <名称> <路径>  添加 skill 到仓库"
    echo "  ${GREEN}add${NC} .              添加所有 skill"
    echo "  ${GREEN}remove${NC} <名称>     从仓库删除 skill"
    echo "  ${GREEN}list${NC}              列出所有 skill"
    echo ""
    echo "${CYAN}同步命令:${NC}"
    echo "  ${GREEN}sync${NC}              同步所有 skill 到各 Agent"
    echo "  ${GREEN}pull${NC} <名称>       从仓库拉取 skill 到当前 Agent"
    echo "  ${GREEN}push${NC} <名称>       推送 skill 到仓库"
    echo ""
    echo "${CYAN}远程命令:${NC}"
    echo "  ${GREEN}remote${NC} add <名称> <URL>  添加远程仓库"
    echo "  ${GREEN}remote${NC} remove <名称>     删除远程仓库"
    echo "  ${GREEN}remote${NC} list              列出远程仓库"
    echo "  ${GREEN}fetch${NC}                     从远程仓库获取更新"
    echo "  ${GREEN}pull${NC} origin               从远程仓库拉取"
    echo "  ${GREEN}push${NC} origin               推送到远程仓库"
    echo ""
    echo "${CYAN}查看命令:${NC}"
    echo "  ${GREEN}status${NC}            查看部署状态"
    echo "  ${GREEN}diff${NC} <名称>       查看 skill 变更"
    echo "  ${GREEN}log${NC}               查看提交历史"
    echo ""
    echo "${CYAN}示例:${NC}"
    echo "  skill-once init                    # 初始化仓库"
    echo "  skill-once add my-skill ./my-skill # 添加 skill"
    echo "  skill-once add .                   # 添加所有 skill"
    echo "  skill-once sync                    # 同步到所有 Agent"
    echo "  skill-once pull my-skill           # 拉取 skill"
    echo "  skill-once remote add origin https://github.com/user/repo.git"
    echo "  skill-once push origin             # 推送到远程"
    echo ""
    echo "更多信息请访问: https://github.com/zhouhao111/skill-once"
}

# 初始化
cmd_init() {
    echo -e "${BLUE}🔧 初始化 skill 仓库${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/init.sh"
}

# 添加 skill
cmd_add() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once add <名称> <路径>${NC}"
        echo "   或: skill-once add . (添加所有 skill)"
        exit 1
    fi
    
    # 添加所有 skill
    if [ "$1" = "." ]; then
        echo -e "${BLUE}📦 添加所有 skill${NC}"
        echo ""
        bash "$SKILL_ONCE/scripts/add-all.sh"
        return
    fi
    
    # 添加指定 skill
    if [ -z "$2" ]; then
        echo -e "${RED}❌ 用法: skill-once add <名称> <路径>${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}📦 添加 skill: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/add.sh" "$1" "$2"
}

# 删除 skill
cmd_remove() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once remove <名称>${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}🗑️  删除 skill: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/remove.sh" "$1"
}

# 列出 skill
cmd_list() {
    # 读取配置
    if [ -f "$CONFIG" ]; then
        SKILL_DIR=$(grep "^skill_dir:" "$CONFIG" | awk '{print $2}')
        SKILL_DIR=$(eval echo "$SKILL_DIR")
    else
        SKILL_DIR="$HOME/.agents/.mySkillRepository"
    fi
    
    echo -e "${BLUE}📦 Skill 列表${NC}"
    echo ""
    echo "  仓库位置: $SKILL_DIR"
    echo ""
    
    if [ ! -d "$SKILL_DIR" ]; then
        echo -e "  ${RED}❌ 仓库目录不存在${NC}"
        exit 1
    fi
    
    count=0
    for skill in "$SKILL_DIR"/*/; do
        [ -d "$skill" ] || continue
        name=$(basename "$skill")
        echo "  - $name"
        ((count++))
    done
    
    echo ""
    echo "  共 $count 个 skill"
}

# 同步 skill
cmd_sync() {
    echo -e "${BLUE}🔄 同步 skill...${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/sync.sh" "$@"
}

# 推送 skill 到仓库
cmd_push() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once push <名称> <路径>${NC}"
        echo "   或: skill-once push origin (推送到远程仓库)"
        exit 1
    fi
    
    # 推送到远程仓库
    if [ "$1" = "origin" ] || [ "$1" = "github" ] || [ "$1" = "gitee" ]; then
        echo -e "${BLUE}📤 推送到远程仓库: $1${NC}"
        echo ""
        bash "$SKILL_ONCE/scripts/push-remote.sh" "$1"
        return
    fi
    
    # 推送 skill 到仓库
    if [ -z "$2" ]; then
        echo -e "${RED}❌ 用法: skill-once push <名称> <路径>${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}📦 推送 skill 到仓库: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/push-to-repo.sh" "$1" "$2"
}

# 拉取 skill
cmd_pull() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once pull <名称>${NC}"
        echo "   或: skill-once pull origin (从远程仓库拉取)"
        exit 1
    fi
    
    # 从远程仓库拉取
    if [ "$1" = "origin" ] || [ "$1" = "github" ] || [ "$1" = "gitee" ]; then
        echo -e "${BLUE}📥 从远程仓库拉取: $1${NC}"
        echo ""
        bash "$SKILL_ONCE/scripts/pull-remote.sh" "$1"
        return
    fi
    
    # 从仓库拉取 skill
    echo -e "${BLUE}📥 拉取 skill: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/pull.sh" "$1"
}

# 远程仓库管理
cmd_remote() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once remote <add|remove|list>${NC}"
        exit 1
    fi
    
    case "$1" in
        add)
            if [ -z "$2" ] || [ -z "$3" ]; then
                echo -e "${RED}❌ 用法: skill-once remote add <名称> <URL>${NC}"
                exit 1
            fi
            echo -e "${BLUE}🔗 添加远程仓库: $2${NC}"
            echo ""
            bash "$SKILL_ONCE/scripts/remote-add.sh" "$2" "$3"
            ;;
        remove|rm)
            if [ -z "$2" ]; then
                echo -e "${RED}❌ 用法: skill-once remote remove <名称>${NC}"
                exit 1
            fi
            echo -e "${YELLOW}🗑️  删除远程仓库: $2${NC}"
            echo ""
            bash "$SKILL_ONCE/scripts/remote-remove.sh" "$2"
            ;;
        list|ls)
            echo -e "${BLUE}🔗 远程仓库列表${NC}"
            echo ""
            bash "$SKILL_ONCE/scripts/remote-list.sh"
            ;;
        *)
            echo -e "${RED}❌ 未知命令: $1${NC}"
            echo ""
            echo "用法: skill-once remote <add|remove|list>"
            exit 1
            ;;
    esac
}

# 从远程仓库获取更新
cmd_fetch() {
    echo -e "${BLUE}📥 从远程仓库获取更新...${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/fetch.sh"
}

# 查看状态
cmd_status() {
    echo -e "${BLUE}📊 部署状态${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/status.sh"
}

# 查看变更
cmd_diff() {
    if [ -z "$1" ]; then
        echo -e "${RED}❌ 用法: skill-once diff <名称>${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}📝 查看变更: $1${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/diff.sh" "$1"
}

# 查看提交历史
cmd_log() {
    echo -e "${BLUE}📜 提交历史${NC}"
    echo ""
    bash "$SKILL_ONCE/scripts/log.sh"
}

# 主函数
main() {
    case "${1:-help}" in
        init)
            cmd_init
            ;;
        add)
            shift
            cmd_add "$@"
            ;;
        remove|rm)
            shift
            cmd_remove "$@"
            ;;
        list|ls)
            cmd_list
            ;;
        sync)
            shift
            cmd_sync "$@"
            ;;
        push)
            shift
            cmd_push "$@"
            ;;
        pull)
            shift
            cmd_pull "$@"
            ;;
        remote)
            shift
            cmd_remote "$@"
            ;;
        fetch)
            cmd_fetch
            ;;
        status|st)
            cmd_status
            ;;
        diff)
            shift
            cmd_diff "$@"
            ;;
        log)
            cmd_log
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}❌ 未知命令: $1${NC}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
